# ==============================================================================
# RealSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env in the backend directory
# 2. Fill in all the placeholder values with your actual API keys and settings
# 3. NEVER commit the .env file to version control
# 4. Keep your API keys and secrets secure
# 5. Use different values for development, staging, and production environments
#
# ==============================================================================

# ==============================================================================
# 1. ENVIRONMENT & APPLICATION SETTINGS
# ==============================================================================
# Environment mode: development, staging, or production
ENVIRONMENT=development

# Enable debug mode (MUST be false in production)
DEBUG=true

# Application name and version
APP_NAME=RealSTEM
VERSION=1.0.0

# ==============================================================================
# 2. SERVER SETTINGS
# ==============================================================================
# Server host (use 0.0.0.0 to expose to network, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Server port
PORT=8000

# API prefix for all endpoints
API_PREFIX=/api

# ==============================================================================
# 3. DATABASE - PostgreSQL
# ==============================================================================
# PostgreSQL connection URL format: postgresql://username:password@host:port/database
# Replace with your actual database credentials
DATABASE_URL=postgresql://realstem:realstem_password@localhost:5432/realstem

# Echo SQL queries to console for debugging (development only)
DATABASE_ECHO=false

# Database connection pool settings
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=40
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=3600

# ==============================================================================
# 4. REDIS & CACHING
# ==============================================================================
# Redis connection URL for caching and session storage
# Format: redis://[password@]host:port/db_number
REDIS_URL=redis://localhost:6379/0

# Cache TTL (Time To Live) in seconds - default 1 hour
CACHE_TTL=3600

# Enable/disable caching globally
CACHE_ENABLED=true

# ==============================================================================
# 5. SECURITY SETTINGS
# ==============================================================================
# Secret key for encrypting session data and JWT tokens
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-immediately

# JWT algorithm for token signing
ALGORITHM=HS256

# JWT access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT refresh token expiration time in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# 6. CORS (Cross-Origin Resource Sharing)
# ==============================================================================
# Frontend URLs allowed to access the API (comma-separated list)
# For development: include your frontend dev server URLs
# For production: only include your actual frontend domain
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174"]

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# HTTP methods allowed
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]

# Headers allowed in requests
CORS_ALLOW_HEADERS=["*"]

# ==============================================================================
# 7. AI & LLM API KEYS - Get from respective platforms
# ==============================================================================
# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API Key
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (if using GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face API Token
# Get from: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=your_hugging_face_token_here

# ==============================================================================
# 8. NEWS AGGREGATION API KEYS
# ==============================================================================
# NewsAPI.org API Key for fetching technology and science news
# Get from: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# Reddit OAuth2 Credentials for accessing Reddit API
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Reddit User-Agent (used to identify your app to Reddit's API)
# Format: AppName/Version by Username
REDDIT_USER_AGENT=RealSTEM/1.0 by YourRedditUsername

# ==============================================================================
# 9. MEDIA & TRANSLATION API KEYS
# ==============================================================================
# Google Cloud Text-to-Speech API Key
# Get from: https://cloud.google.com/text-to-speech
GOOGLE_CLOUD_TTS_API_KEY=your_google_cloud_tts_key_here

# Google Cloud Project ID (for TTS and other Google services)
# Find in: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT_ID=your_google_project_id_here

# DeepL Translation API Key
# Get from: https://www.deepl.com/pro
DEEPL_API_KEY=your_deepl_api_key_here

# DeepL API URL (use free or pro endpoint based on your plan)
# Free: https://api-free.deepl.com/v1
# Pro: https://api.deepl.com/v1
DEEPL_API_URL=https://api-free.deepl.com/v1

# ==============================================================================
# 10. BACKGROUND TASKS - CELERY & REDIS
# ==============================================================================
# Celery Message Broker (Redis URL for task queue)
# Use different Redis DB number (1) to avoid cache conflicts
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery Result Backend (where task results are stored)
# Use different Redis DB number (2)
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Celery timezone for scheduled tasks
CELERY_TIMEZONE=UTC

# Track task state and progress
CELERY_TASK_TRACK_STARTED=true

# Maximum task execution time in seconds (30 minutes)
CELERY_TASK_TIME_LIMIT=1800

# ==============================================================================
# 11. EMAIL CONFIGURATION
# ==============================================================================
# SMTP server host (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP authentication password or app-specific password
# For Gmail: Use app-specific password from https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-specific-password

# Email address that sends notifications
SENDER_EMAIL=noreply@realstem.edu

# Display name for sender
SENDER_NAME=RealSTEM

# ==============================================================================
# 12. LOGGING CONFIGURATION
# ==============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log message format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Log file path (relative to project root)
LOG_FILE=logs/realstem.log

# ==============================================================================
# 13. PAGINATION SETTINGS
# ==============================================================================
# Default number of items per page in API responses
DEFAULT_PAGE_SIZE=20

# Maximum allowed items per page
MAX_PAGE_SIZE=100

# ==============================================================================
# 14. RATE LIMITING
# ==============================================================================
# Enable/disable rate limiting on API endpoints
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per IP address
RATE_LIMIT_PER_MINUTE=60

# ==============================================================================
# 15. FEATURE FLAGS - Control which features are enabled
# ==============================================================================
# Enable video generation from lesson content
ENABLE_VIDEO_GENERATION=true

# Enable interactive simulations and virtual experiments
ENABLE_SIMULATIONS=true

# Enable global challenges and competitions
ENABLE_GLOBAL_CHALLENGES=true

# Enable real-time collaboration with WebSockets
ENABLE_REAL_TIME_COLLABORATION=true

# Enable ML-based personalized recommendations
ENABLE_ML_RECOMMENDATIONS=true

# Enable multi-language support and translations
ENABLE_MULTI_LANGUAGE=true

# Enable news aggregation and STEM news feed
ENABLE_NEWS_AGGREGATION=true

# Enable career path matching and recommendations
ENABLE_CAREER_MATCHING=true

# Enable analytics and progress tracking
ENABLE_ANALYTICS=true

# ==============================================================================
# 16. MODEL & CONTENT CONSTRAINTS
# ==============================================================================
# Maximum length of lesson content in characters
MAX_LESSON_CONTENT_LENGTH=100000

# Maximum length of news description in characters
MAX_NEWS_DESCRIPTION_LENGTH=5000

# Maximum video duration in minutes
MAX_VIDEO_DURATION_MINUTES=120

# ==============================================================================
# 17. AWS / CLOUD STORAGE (Optional)
# ==============================================================================
# AWS Access Key ID (for S3 file storage)
# Get from: https://console.aws.amazon.com/
AWS_ACCESS_KEY_ID=your_aws_access_key_here

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS region
AWS_REGION=us-east-1

# S3 bucket name for storing content (videos, lesson materials, etc.)
AWS_S3_BUCKET=realstem-content

# ==============================================================================
# 18. FRONTEND CONFIGURATION
# ==============================================================================
# Backend API URL that frontend will call
REACT_APP_API_URL=http://localhost:8000/api

# WebSocket URL for real-time features
REACT_APP_WS_URL=ws://localhost:8000/ws

# Frontend environment
REACT_APP_ENVIRONMENT=development

# ==============================================================================
# NOTES FOR DEPLOYMENT
# ==============================================================================
# Development:
#   - Use DEBUG=true, ENVIRONMENT=development
#   - Set CORS_ORIGINS to localhost addresses
#   - Use localhost database URLs
#
# Production:
#   - Set DEBUG=false, ENVIRONMENT=production
#   - Use secure, randomly generated SECRET_KEY
#   - Set CORS_ORIGINS to actual frontend domain(s)
#   - Use managed cloud databases (RDS, Cloud SQL, etc.)
#   - Use environment variables from secrets manager
#   - Enable HTTPS/TLS for all connections
#   - Rotate API keys regularly
#   - Never commit .env file to version control
#
# ==============================================================================

